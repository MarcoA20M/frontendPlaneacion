/* ========== ESTILOS PARA ACCESO RÁPIDO A TRAZABILIDAD ========== */

.quick-access-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 15px;
    margin-top: 5px;
}

.quick-access-card {
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid rgba(192, 0, 255, 0.2);
    border-radius: 14px;
    padding: 14px 16px;
    display: flex;
    align-items: center;
    gap: 14px;
    cursor: pointer;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
}

.quick-access-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(192, 0, 255, 0.1), transparent);
    transition: left 0.5s ease;
}

.quick-access-card:hover::before {
    left: 100%;
}

.quick-access-card:hover {
    transform: translateY(-3px);
    border-color: rgba(192, 0, 255, 0.5);
    box-shadow: 0 5px 20px rgba(128, 0, 255, 0.25);
    background: rgba(192, 0, 255, 0.08);
}

.quick-access-card.more {
    background: rgba(0, 0, 0, 0.2);
    border-style: dashed;
    border-color: rgba(192, 0, 255, 0.3);
}

.quick-access-card.more:hover {
    background: rgba(192, 0, 255, 0.08);
    border-style: solid;
}

.quick-icon {
    font-size: 32px;
    filter: drop-shadow(0 0 5px rgba(192, 0, 255, 0.4));
    transition: transform 0.3s ease;
}

.quick-access-card:hover .quick-icon {
    transform: scale(1.1);
}

.quick-info {
    flex: 1;
}

.quick-info strong {
    display: block;
    font-size: 14px;
    font-weight: 600;
    color: #e879f9;
    margin-bottom: 4px;
}

.quick-info small {
    font-size: 10px;
    color: rgba(255, 255, 255, 0.5);
}

.quick-arrow {
    font-size: 20px;
    color: #c000ff;
    opacity: 0;
    transform: translateX(-10px);
    transition: all 0.3s ease;
}

.quick-access-card:hover .quick-arrow {
    opacity: 1;
    transform: translateX(0);
}

/* Estilos para el botón de ver trazabilidad en las tarjetas de tanques */
.btn-ver-trazabilidad {
    background: linear-gradient(135deg, rgba(192, 0, 255, 0.2), rgba(128, 0, 255, 0.1));
    border: 1px solid rgba(192, 0, 255, 0.4);
