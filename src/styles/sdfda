/* ============================================
   RESET Y ESTILOS BASE
   ============================================ */

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

/* ============================================
   CONTENEDOR PRINCIPAL
   ============================================ */

.criticos-container {
    width: 100vw;
    height: 100vh;
    background: var(--crit-bg);
    overflow: hidden;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    transition: background 0.3s ease;
}

.criticos-glass-panel {
    display: flex;
    height: 100vh;
    width: 100%;
    background: var(--crit-glass-bg);
    backdrop-filter: blur(4px);
    transition: background 0.3s ease;
}

/* ============================================
   SIDEBAR
   ============================================ */

.criticos-sidebar {
    width: 280px;
    background: var(--crit-sidebar-bg);
    border-right: 1px solid var(--crit-sidebar-border);
    display: flex;
    flex-direction: column;
    padding: 24px 16px;
    box-shadow: var(--crit-sidebar-shadow);
    transition: all 0.3s ease;
}

.sidebar-logo {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 32px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--crit-logo-border);
}

.logo-icon {
    font-size: 32px;
    filter: var(--crit-logo-icon-filter);
}

.sidebar-logo h2 {
    font-size: 16px;
    background: var(--crit-logo-text);
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
    margin: 0;
}

.sidebar-nav {
    flex: 1;
}

.nav-label {
    font-size: 10px;
    font-weight: 700;
    color: var(--crit-nav-label);
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin-bottom: 16px;
    padding-left: 12px;
    transition: color 0.3s ease;
}

.sidebar-btn {
    width: 100%;
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    background: transparent;
    border: none;
    border-radius: 12px;
    color: var(--crit-nav-btn-color);
    font-size: 14px;
    cursor: pointer;
    transition: all 0.25s ease;
    margin-bottom: 4px;
    position: relative;
}

.sidebar-btn:hover {
    background: var(--crit-nav-btn-hover-bg);
    color: var(--crit-nav-btn-hover-color);
    transform: translateX(4px);
}

.sidebar-btn.active {
    background: var(--crit-nav-btn-active-bg);
    color: var(--crit-nav-btn-active-color);
    border-left: 2px solid var(--crit-nav-btn-active-border);
}

.btn-icon {
    font-size: 18px;
}

.badge-alerta {
    position: absolute;
    right: 16px;
    background: var(--crit-badge-alerta-bg);
    color: var(--crit-badge-alerta-color);
    font-size: 10px;
    font-weight: bold;
    padding: 2px 8px;
    border-radius: 20px;
    box-shadow: var(--crit-badge-alerta-shadow);
}

.sidebar-footer {
    margin-top: auto;
    padding-top: 20px;
    border-top: 1px solid var(--crit-sidebar-footer-border);
}

.stats-resumen-sidebar {
    display: flex;
    justify-content: space-between;
    margin-bottom: 16px;
    background: var(--crit-stats-bg);
    border-radius: 12px;
    padding: 12px;
}

.stat-sidebar {
    text-align: center;
    flex: 1;
}

.stat-sidebar .stat-value {
    display: block;
    font-size: 20px;
    font-weight: 700;
    color: var(--crit-stat-value-color);
    transition: color 0.3s ease;
}

.stat-sidebar .stat-label {
    font-size: 9px;
    color: var(--crit-stat-label-color);
    text-transform: uppercase;
    transition: color 0.3s ease;
}

.btn-volver {
    width: 100%;
    padding: 10px;
    background: var(--crit-btn-volver-bg);
    border: 1px solid var(--crit-btn-volver-border);
    border-radius: 12px;
    color: var(--crit-btn-volver-color);
    cursor: pointer;
    font-weight: 600;
    transition: all 0.2s;
}

.btn-volver:hover {
    background: var(--crit-btn-volver-hover-bg);
    transform: translateX(-2px);
}

/* ============================================
   MAIN CONTENT
   ============================================ */

.criticos-main {
    flex: 1;
    overflow-y: auto;
    padding: 24px 28px;
}

.criticos-main::-webkit-scrollbar {
    width: 6px;
}

.criticos-main::-webkit-scrollbar-track {
    background: var(--crit-main-scroll-track);
    border-radius: 3px;
}

.criticos-main::-webkit-scrollbar-thumb {
    background: var(--crit-main-scroll-thumb);
    border-radius: 3px;
}

/* Header */
.criticos-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 28px;
    flex-wrap: wrap;
    gap: 16px;
}

.header-titulo h1 {
    font-size: 24px;
    font-weight: 700;
    background: var(--crit-header-title);
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
    margin: 0 0 6px 0;
}

.header-titulo p {
    font-size: 13px;
    color: var(--crit-header-sub);
    margin: 0;
    transition: color 0.3s ease;
}

.header-stats {
    display: flex;
    gap: 12px;
}

.stat-card-header {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 18px;
    border-radius: 12px;
    background: var(--crit-stat-card-bg);
    backdrop-filter: blur(4px);
    transition: background 0.3s ease;
}

.stat-card-header.critico {
    border-left: 3px solid var(--crit-stat-card-critico-border);
}

.stat-card-header.alerta {
    border-left: 3px solid var(--crit-stat-card-alerta-border);
}

.stat-card-header .stat-num {
    font-size: 22px;
    font-weight: 700;
    color: var(--crit-stat-num-color);
    transition: color 0.3s ease;
}

.stat-card-header .stat-label {
    font-size: 10px;
    font-weight: 600;
    color: var(--crit-stat-label);
    text-transform: uppercase;
    transition: color 0.3s ease;
}

/* ============================================
   FILTROS
   ============================================ */

.filtros-section {
    margin-bottom: 24px;
}

.filtros-botones {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
}

.filtro-btn {
    background: var(--crit-filtro-btn-bg);
    border: 1px solid var(--crit-filtro-btn-border);
    color: var(--crit-filtro-btn-color);
    padding: 8px 20px;
    border-radius: 30px;
    cursor: pointer;
    transition: all 0.2s;
    font-weight: 500;
    font-size: 12px;
}

.filtro-btn:hover {
    background: var(--crit-filtro-btn-hover-bg);
    border-color: var(--crit-filtro-btn-hover-border);
    transform: translateY(-1px);
}

.filtro-btn.active {
    background: var(--crit-filtro-btn-active-bg);
    border-color: var(--crit-filtro-btn-active-border);
    color: var(--crit-filtro-btn-active-color);
    box-shadow: var(--crit-filtro-btn-active-shadow);
}

/* ============================================
   DASHBOARD CARDS
   ============================================ */

.dashboard-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 20px;
    margin-bottom: 28px;
}

.dashboard-card {
    display: flex;
    align-items: center;
    gap: 16px;
    background: var(--crit-dashboard-card-bg);
    backdrop-filter: blur(10px);
    border-radius: 20px;
    padding: 20px;
    border: 1px solid var(--crit-dashboard-card-border);
    transition: all 0.3s;
}

.dashboard-card:hover {
    transform: translateY(-3px);
    border-color: var(--crit-dashboard-card-hover-border);
    box-shadow: var(--crit-dashboard-card-hover-shadow);
}

.card-icon {
    font-size: 32px;
}

.card-info {
    flex: 1;
}

.card-value {
    display: block;
    font-size: 28px;
    font-weight: 700;
    color: var(--crit-card-value-color);
    transition: color 0.3s ease;
}

.card-label {
    font-size: 11px;
    font-weight: 600;
    color: var(--crit-card-label);
    text-transform: uppercase;
    transition: color 0.3s ease;
}

/* ============================================
   DASHBOARD SECTIONS
   ============================================ */

.dashboard-section {
    background: var(--crit-section-bg);
    backdrop-filter: blur(10px);
    border-radius: 20px;
    padding: 20px;
    margin-bottom: 24px;
    border: 1px solid var(--crit-section-border);
    transition: all 0.3s ease;
}

.dashboard-section h3 {
    font-size: 15px;
    font-weight: 600;
    color: var(--crit-section-title);
    margin: 0 0 16px 0;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: color 0.3s ease;
}

/* ============================================
   TANQUES MINI
   ============================================ */

.tanques-mini-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 14px;
}

.tanque-mini-card {
    background: var(--crit-tanque-mini-bg);
    border-radius: 14px;
    padding: 12px;
    border: 1px solid var(--crit-tanque-mini-border);
    transition: all 0.2s;
}

.tanque-mini-card:hover {
    border-color: var(--crit-tanque-mini-hover-border);
}

.tanque-mini-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px;
}

.tanque-mini-nombre {
    font-size: 12px;
    font-weight: 600;
    color: var(--crit-tanque-mini-nombre);
    transition: color 0.3s ease;
}

.tanque-mini-estado {
    font-size: 10px;
    font-weight: 700;
    padding: 2px 8px;
    border-radius: 20px;
}

.tanque-mini-estado.critico {
    background: var(--crit-tanque-mini-estado-critico-bg);
    color: var(--crit-tanque-mini-estado-critico-color);
}

.tanque-mini-estado.alerta {
    background: var(--crit-tanque-mini-estado-alerta-bg);
    color: var(--crit-tanque-mini-estado-alerta-color);
}

.tanque-mini-estado.normal {
    background: var(--crit-tanque-mini-estado-normal-bg);
    color: var(--crit-tanque-mini-estado-normal-color);
}

.tanque-mini-barra {
    width: 100%;
    height: 6px;
    background: var(--crit-tanque-mini-barra-bg);
    border-radius: 3px;
    overflow: hidden;
    margin-bottom: 8px;
}

.barra-lleno {
    height: 100%;
    transition: width 0.3s;
    border-radius: 3px;
}

.tanque-mini-detalle {
    font-size: 10px;
    color: var(--crit-tanque-mini-detalle);
    text-align: right;
    transition: color 0.3s ease;
}

/* ============================================
   CONSUMOS MINI
   ============================================ */

.consumos-mini-tabla {
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.consumo-mini-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 12px;
    background: var(--crit-consumo-item-bg);
    border-radius: 10px;
    transition: all 0.2s;
}

.consumo-mini-item:hover {
    background: var(--crit-consumo-item-hover);
}

.consumo-mini-info {
    display: flex;
    gap: 16px;
    align-items: center;
    flex-wrap: wrap;
}

.consumo-mini-fecha {
    font-size: 10px;
    color: var(--crit-consumo-fecha);
    transition: color 0.3s ease;
}

.consumo-mini-producto {
    font-size: 12px;
    font-weight: 600;
    color: var(--crit-consumo-producto);
    transition: color 0.3s ease;
}

.consumo-mini-lote {
    font-size: 9px;
    font-family: monospace;
    color: var(--crit-consumo-lote-color);
    background: var(--crit-consumo-lote-bg);
    padding: 2px 6px;
    border-radius: 4px;
    transition: all 0.3s ease;
}

.consumo-mini-cantidad {
    font-size: 12px;
    font-weight: 700;
    color: var(--crit-consumo-cantidad);
    transition: color 0.3s ease;
}

/* ============================================
