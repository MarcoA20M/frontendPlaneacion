    height: 50px;
    border: 3px solid rgba(192, 0, 255, 0.3);
    border-top-color: #c000ff;
    border-radius: 50%;
    animation: spin 1s linear infinite;
    margin-bottom: 20px;
    box-shadow: 0 0 15px rgba(192, 0, 255, 0.3);
}

@keyframes spin {
