/* ========== ESTILOS PARA HEADER DE FÓRMULAS CON IMAGEN DE FAMILIA ========== */

.formula-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 20px;
    background: linear-gradient(135deg, rgba(0, 0, 0, 0.4), rgba(128, 0, 255, 0.1));
    border-bottom: 1px solid rgba(192, 0, 255, 0.2);
    flex-wrap: wrap;
    gap: 16px;
}

.formula-header-info {
    display: flex;
    align-items: center;
    gap: 20px;
    flex: 1;
}

/* Contenedor de la imagen */
.formula-imagen-wrap {
    flex-shrink: 0;
}

.formula-imagen-circle {
    position: relative;
    width: 70px;
    height: 70px;
    border-radius: 50%;
    overflow: hidden;
    background: linear-gradient(135deg, rgba(192, 0, 255, 0.3), rgba(128, 0, 255, 0.2));
    border: 2px solid rgba(192, 0, 255, 0.5);
    box-shadow: 0 4px 15px rgba(128, 0, 255, 0.3);
    transition: all 0.3s ease;
    cursor: pointer;
}

.formula-imagen-circle:hover {
    transform: scale(1.05);
    box-shadow: 0 6px 20px rgba(192, 0, 255, 0.4);
    border-color: #e879f9;
}

.formula-imagen-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
}

.formula-imagen-fallback {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 32px;
    background: linear-gradient(135deg, #c000ff, #7c00b3);
    border-radius: 50%;
}

.formula-imagen-badge {
    position: absolute;
    bottom: -5px;
    right: -5px;
    width: 26px;
    height: 26px;
    background: linear-gradient(135deg, #e879f9, #c000ff);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    font-weight: bold;
    color: white;
    border: 2px solid #fff;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
}

.formula-imagen-placeholder {
    width: 70px;
    height: 70px;
    border-radius: 50%;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.05), rgba(192, 0, 255, 0.1));
    border: 2px dashed rgba(192, 0, 255, 0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
}

.formula-placeholder-content {
    text-align: center;
}

.formula-placeholder-icon {
    font-size: 28px;
    display: block;
    opacity: 0.6;
}

.formula-placeholder-text {
    font-size: 8px;
    color: rgba(255, 255, 255, 0.4);
    display: block;
    margin-top: 4px;
}

.formula-imagen-loading {
    width: 70px;
    height: 70px;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.3);
    display: flex;
    align-items: center;
    justify-content: center;
}

.formula-spinner {
    width: 24px;
    height: 24px;
    border: 2px solid rgba(192, 0, 255, 0.3);
    border-top-color: #c000ff;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
}

/* Información del producto */
.formula-info-text {
    flex: 1;
}

.formula-code-row {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 6px;
    flex-wrap: wrap;
}

.formula-code-badge {
    font-size: 9px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: #a855f7;
    background: rgba(168, 85, 247, 0.15);
    padding: 2px 8px;
    border-radius: 12px;
}

.formula-code-value {
    font-size: 13px;
    font-weight: 600;
    color: #e879f9;
    font-family: monospace;
    background: rgba(0, 0, 0, 0.3);
    padding: 2px 8px;
    border-radius: 6px;
}

.formula-name {
    font-size: 16px;
    font-weight: 700;
    color: #fff;
    margin: 0 0 6px 0;
    line-height: 1.3;
    background: linear-gradient(135deg, #fff, #e879f9);
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
}

.formula-family-tag {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(192, 0, 255, 0.15);
    padding: 4px 10px;
    border-radius: 20px;
    font-size: 10px;
    color: #c4b5fd;
    border: 1px solid rgba(192, 0, 255, 0.3);
}

.formula-family-tag-warning {
    background: rgba(243, 156, 18, 0.15);
    border-color: rgba(243, 156, 18, 0.3);
    color: #f39c12;
}

.formula-family-icon {
    font-size: 10px;
}

/* Acciones del header */
.formula-actions {
    display: flex;
    gap: 12px;
    align-items: center;
    flex-wrap: wrap;
}

/* Responsive */
@media (max-width: 768px) {
    .formula-header {
        flex-direction: column;
        align-items: flex-start;
    }
    
    .formula-header-info {
        width: 100%;
    }
    
    .formula-actions {
        width: 100%;
        justify-content: flex-start;
    }
    
    .formula-imagen-circle,
    .formula-imagen-placeholder,
    .formula-imagen-loading {
        width: 55px;
        height: 55px;
    }
    
    .formula-name {
        font-size: 14px;
    }
}

@media (max-width: 480px) {
    .formula-header-info {
        flex-direction: column;
        text-align: center;
    }
    
    .formula-code-row {
        justify-content: center;
    }
    
    .formula-family-tag {
        align-self: center;
    }
}

/* ========== INDICADOR DE ACTUALIZACIÓN ========== */
.actualizando-badge {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 4px 12px;
    background: rgba(0, 0, 0, 0.3);
    border-radius: 20px;
    font-size: 11px;
    color: rgba(255, 255, 255, 0.6);
}

.stat-card-header.actualizando {
    border-left: 3px solid #3498db;
    gap: 6px;
}

.spinner-mini {
    width: 14px;
    height: 14px;
    border: 2px solid rgba(192, 0, 255, 0.3);
    border-top-color: #c000ff;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
}

@keyframes spin {
    to { transform: rotate(360deg); }
}



/* ========== PAGINACIÓN ========== */
.paginacion-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 16px;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    margin-top: 8px;
    flex-wrap: wrap;
    gap: 10px;
}

.paginacion-info {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.5);
}

.paginacion-botones {
    display: flex;
    gap: 4px;
    align-items: center;
}

.paginacion-btn {
    padding: 4px 10px;
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 6px;
    color: rgba(255, 255, 255, 0.7);
    cursor: pointer;
    transition: all 0.2s;
    font-size: 12px;
    min-width: 32px;
    text-align: center;
}

.paginacion-btn:hover:not(:disabled) {
    background: rgba(192, 0, 255, 0.2);
    border-color: rgba(192, 0, 255, 0.3);
    color: #e879f9;
}

.paginacion-btn.active {
    background: linear-gradient(135deg, rgba(192, 0, 255, 0.3), rgba(128, 0, 255, 0.2));
    border-color: #c000ff;
    color: #e879f9;
    font-weight: 600;
}

.paginacion-btn:disabled {
    opacity: 0.3;
    cursor: not-allowed;
}

.paginacion-puntos {
    color: rgba(255, 255, 255, 0.3);
    padding: 0 4px;
}

/* Responsive */
@media (max-width: 768px) {
    .paginacion-container {
        flex-direction: column;
        align-items: center;
    }
    
    .paginacion-botones {
        flex-wrap: wrap;
        justify-content: center;
    }
}


/* ========== ALERTAS CON CÓDIGO ========== */
.alerta-titulo {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
}

.alerta-titulo h4 {
    font-size: 14px;
    font-weight: 600;
    color: #fff;
    margin: 0;
}

.alerta-codigo {
    font-size: 10px;
    font-weight: 700;
    padding: 2px 10px;
    border-radius: 12px;
    background: rgba(168, 85, 247, 0.2);
    color: #a855f7;
    font-family: monospace;
    letter-spacing: 0.5px;
}

.alerta-card.critica .alerta-codigo {
    background: rgba(231, 76, 60, 0.2);
    color: #e74c3c;
}

.alerta-card.precaucion .alerta-codigo {
    background: rgba(243, 156, 18, 0.2);
    color: #f39c12;
}

.alerta-info p {
    font-size: 11px;
    color: rgba(255, 255, 255, 0.6);
    margin: 4px 0 0 0;
}

.alerta-info p strong {
    color: #fff;
}

/* Responsive */
@media (max-width: 480px) {
    .alerta-titulo {
        flex-direction: column;
        align-items: flex-start;
        gap: 4px;
    }
    
    .alerta-titulo h4 {
        font-size: 13px;
    }
    
    .alerta-codigo {
        font-size: 9px;
        padding: 1px 8px;
    }
}


















